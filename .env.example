# ==============================================================================
# VeylanLabs Environment Configuration
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to git.
# ==============================================================================

# ── 1. Application URL ─────────────────────────────────────────────────────────
# Change to your real domain when deploying (e.g. https://veylanlabs.com)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── 2. Clerk Authentication ───────────────────────────────────────────────────
# Found in Clerk Dashboard → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/login
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Clerk Webhook Secret (Clerk Dashboard → Webhooks → your endpoint → Signing Secret)
# Needed to link Stripe guest-checkouts to Clerk accounts when user registers later.
CLERK_WEBHOOK_SECRET=whsec_...

# ── 3. Supabase Database ──────────────────────────────────────────────────────
# Found in Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Service Role Key — NEVER expose this publicly!
# Required for server-side API routes to bypass Row Level Security.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── 4. Stripe Payments ────────────────────────────────────────────────────────
# Found in Stripe Dashboard → Developers → API Keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# Webhook Secret (Stripe Dashboard → Developers → Webhooks → Signing Secret)
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs — create these in Stripe Dashboard → Products
# Member tier
NEXT_PUBLIC_STRIPE_PRICE_MEMBER_MONTHLY=price_...
NEXT_PUBLIC_STRIPE_PRICE_MEMBER_QUARTERLY=price_...
NEXT_PUBLIC_STRIPE_PRICE_MEMBER_ANNUAL=price_...

# Inner Circle tier
NEXT_PUBLIC_STRIPE_PRICE_INNER_MONTHLY=price_...
NEXT_PUBLIC_STRIPE_PRICE_INNER_QUARTERLY=price_...
NEXT_PUBLIC_STRIPE_PRICE_INNER_ANNUAL=price_...

# ── 5. Telegram Bot ───────────────────────────────────────────────────────────
# Talk to @BotFather on Telegram to create a bot and get the token.
# The bot must be an ADMIN of all your War Room groups/channels.
TELEGRAM_BOT_TOKEN=123456789:ABCDefghIJKLmnopQRSTuvwxYZ

# Chat ID of your MAIN War Room group (all subscribers). Usually starts with -100.
# Add @RawDataBot to your group temporarily to find the chat_id.
TELEGRAM_MAIN_GROUP_ID=-100123456789

# Chat ID of your CHART / Inner Circle group (premium subscribers only).
TELEGRAM_CHART_GROUP_ID=-100987654321

# Bot username (without the @) — shown in the dashboard "Link Telegram" button.
# Found in @BotFather → /mybots → your bot → Bot Settings → Edit Bot Name
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=VeylanLabsBot

# Webhook Secret Token to secure your webhook endpoint from fake requests.
# Set this to any long random string (e.g. openssl rand -hex 32).
TELEGRAM_WEBHOOK_SECRET=your_super_secret_token_here

# ── 6. Admin Access ───────────────────────────────────────────────────────────
# Comma-separated list of emails allowed to access /admin dashboard
ADMIN_EMAILS=you@yourdomain.com

# ── 7. TradingView Automation Worker ─────────────────────────────────────────
# Required if you deploy the tv-worker/ microservice to automate script whitelist.
# The worker exposes POST /api/webhook — set the URL to wherever it is hosted.
#
# TV_WORKER_WEBHOOK_URL=https://your-tv-worker.onrender.com/api/webhook
#
# Shared secret between Next.js and the tv-worker (must match .env in tv-worker/).
# TV_WORKER_SECRET=super_secret_worker_key

# ── 8. Admin ──────────────────────────────────────────────────────────────────
# (already set above in section 6 — listed here for cross-reference)
# ADMIN_EMAILS=you@yourdomain.com
