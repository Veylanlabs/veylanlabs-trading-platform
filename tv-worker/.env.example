# The private password between Next.js and this Worker
WORKER_SECRET=super_secret_worker_key_123

# Your specific TradingView Invite-Only Script URL
# Navigate to your script -> Scroll down to Manage Access
TV_SCRIPT_URL=https://www.tradingview.com/script/YOUR-SCRIPT-ID/manage-access/

# Your TradingView Authentication Cookie
# Log into TradingView -> Inspect Element -> Application -> Cookies -> sessionid
TV_SESSION_ID=your_sessionid_cookie_value_here
PORT=4000
